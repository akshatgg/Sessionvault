{
  "manifest_version": 3,
  "name": "SessionVault",
  "version": "1.0.0",
  "description": "Capture the current tab's cookies + localStorage and export them in Playwright storageState format.",
  "permissions": [
    "cookies",
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export storage state"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sessionvault@local",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
